---
import { name } from 'spectre:globals';
import Icon from './Icon.astro';

const path = Astro.url.pathname;
---
<nav aria-label="Main navigation">
  <a class="site-title" href="/">{name}</a>
  <ul>
    <li>
      <a href="/" class:list={{ active: path === '/' }}>Home</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/blog" class:list={{ active: path.startsWith('/blog') }}>Blog</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/microblog" class:list={{ active: path.startsWith('/microblog') }}>Microblog</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/projects" class:list={{ active: path.startsWith('/projects') }}>Projects</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/resume" class:list={{ active: path.startsWith('/resume') }}>Resume</a>
    </li>
    <li class="search-item">
      <div class="search-wrapper">
        <Icon type="lucide" name="search" width={16} height={16} class="search-icon" />
        <input id="search" type="text" placeholder="Search" />
        <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
      </div>
      <div id="search-results"></div>
    </li>
  </ul>
  <button class="mobile-nav-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
    <Icon type="lucide" name="menu" width={24} height={24} class="menu-closed" />
    <Icon type="lucide" name="x" width={24} height={24} class="menu-open" />
  </button>
</nav>
<script is:inline>
  let pagefindInitialized = false;
  let globalListenersAdded = false;
  let focusIndex = -1;

  const initNavbar = () => {
    const searchElement = document.querySelector('#search');
    const results = document.querySelector('#search-results');
    const navToggle = document.querySelector('.mobile-nav-toggle');

    if (!searchElement || !results || !navToggle) return;

    if (!globalListenersAdded) {
      document.addEventListener('keydown', (e) => {
        const currentSearch = document.querySelector('#search');
        const currentResults = document.querySelector('#search-results');
        if (!currentSearch || !currentResults) return;

        if (e.key === 'k' && (e.ctrlKey || e.metaKey)) {
          e.preventDefault();
          currentSearch.focus();
        }

        if (e.key === 'Escape') {
          currentSearch.blur();
          currentResults.classList.remove('active');
          focusIndex = -1;
        }

        if (e.key === 'ArrowDown') {
          const resultLinks = document.querySelectorAll('#search-results a');
          if (resultLinks.length > 0) {
            e.preventDefault();
            focusIndex++;
            if (focusIndex >= resultLinks.length) focusIndex = 0;
            resultLinks[focusIndex]?.focus();
          }
        }

        if (e.key === 'ArrowUp') {
          const resultLinks = document.querySelectorAll('#search-results a');
          if (resultLinks.length > 0) {
            e.preventDefault();
            focusIndex--;
            if (focusIndex < 0) focusIndex = resultLinks.length - 1;
            resultLinks[focusIndex]?.focus();
          }
        }
      });

      window.addEventListener('resize', () => {
        const currentSearch = document.querySelector('#search');
        if (currentSearch) {
          currentSearch.placeholder = 'Search';
        }
      });

      globalListenersAdded = true;
    }

    searchElement.addEventListener('focus', async () => {
      searchElement.placeholder = '';
      results.classList.add('active');
      
      if (!pagefindInitialized) {
        try {
          // Check if window.pagefind is already loaded (it might be since we use View Transitions)
          if (!window.pagefind) {
            window.pagefind = await import("/pagefind/pagefind.js");
            await window.pagefind.init();
          }
          pagefindInitialized = true;
        } catch (error) {
          console.error('Failed to initialize Pagefind:', error);
        }
      }
    });
    
    searchElement.addEventListener('blur', () => {
      searchElement.placeholder = 'Search';
      setTimeout(() => {
        if (!document.activeElement?.closest('#search-results')) {
          results.classList.remove('active');
          focusIndex = -1;
        }
      }, 1);
    });

    results.addEventListener('focusout', (e) => {
      if (!e.relatedTarget?.closest('#search-results')) {
        results.classList.remove('active');
        focusIndex = -1;
      }
    });

    searchElement.addEventListener('input', async (e) => {
      if (!pagefindInitialized || !window.pagefind) return;

      results.innerHTML = '';
      let searchResultHtml = '';
      const search = await window.pagefind.search(e.target.value);

      let i = 0;
      for (const result of search.results) {
        i++;
        const data = await result.data();
        searchResultHtml += `
          <a href="${data.url}">
            <h3 class="no-mt">${data.meta.title}</h3>
            <p>${data.excerpt}</p>
          </a>
          ${i < search.results.length ? '<hr class="separator">' : ''}
        `;
      }

      if (search.results.length === 0 && e.target.value.length > 0) {
        results.innerHTML = '<p style="margin-top: 0;">No results found</p>';
      } else {
        results.innerHTML = searchResultHtml;
      }
      results.classList.add('active');
    });

    navToggle.addEventListener('click', () => {
      navToggle.classList.toggle('active');
      document.querySelector('nav')?.classList.toggle('active');
      const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', String(!isExpanded));
    });

    // Reset placeholder on load
    searchElement.placeholder = 'Search';
  };

  document.addEventListener('astro:page-load', initNavbar);
</script>
<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Geist', Arial, Helvetica, sans-serif;
    z-index: 50;
  }

  .site-title {
    font-weight: 800;
    text-decoration: none;
    font-size: 1.25em;
    color: var(--text);
    letter-spacing: -0.02em;
    z-index: 2;
  }

  nav ul {
    display: flex;
    gap: .25rem;
    margin: 0;
    padding: 0;
    list-style-type: none;
    align-items: center;
  }

  nav ul li {
    position: relative;
  }

  .nav-separator {
    color: var(--text-subtle);
    opacity: .5;
  }

  nav a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color .2s var(--ease-out-expo);
  }

  nav a:hover, nav a:focus-visible {
    color: var(--text);
    text-decoration: none;
    outline: none;
  }

  nav ul a {
    position: relative;
    padding: .35rem .4rem;
    font-weight: 500;
  }

  nav ul a::after {
    content: "";
    position: absolute;
    left: .4rem;
    right: .4rem;
    bottom: -.15rem;
    height: 2px;
    background: var(--primary);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform .28s var(--ease-out-expo);
  }

  nav ul a:hover::after,
  nav ul a:focus-visible::after,
  nav ul a.active::after {
    transform: scaleX(1);
  }

  nav ul a.active {
    color: var(--text);
  }

  .search-item {
    margin-left: .9rem;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
    gap: .45rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0 .55rem;
    transition: border-color .15s var(--ease-out-expo), box-shadow .15s var(--ease-out-expo);
  }

  .search-wrapper:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px oklch(0.73 var(--accent-c) var(--hue) / 0.18);
  }

  .search-icon {
    color: var(--text-subtle);
    flex: none;
  }

  #search {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    padding: .4rem 0;
    width: 120px;
    font: inherit;
  }

  #search::placeholder {
    color: var(--text-subtle);
  }

  .search-kbd {
    flex: none;
    font-family: var(--font-mono);
    font-size: .7rem;
    line-height: 1.5;
    color: var(--text-subtle);
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0 .3rem;
  }

  #search-results {
    position: absolute;
    top: calc(100% + .5rem);
    right: 0;
    background-color: var(--surface-1);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    display: none;
    width: 200%;
    z-index: 10;
    padding: .5rem;
  }

  #search-results.active:has(*) {
    display: block;
  }

  .mobile-nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    background-color: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    color: var(--text);
  }

  .mobile-nav-toggle :global(svg) {
    color: inherit;
    stroke: currentColor;
  }

  .menu-open {
    display: none;
  }

  .mobile-nav-toggle.active .menu-open {
    display: flex;
  }

  .mobile-nav-toggle.active .menu-closed {
    display: none;
  }

  @media screen and (max-width: 640px) {
    nav {
      padding: 0 1rem;
      padding-top: 1rem;
      transition: all .25s ease;
    }

    .mobile-nav-toggle {
      display: flex;
    }

    .nav-separator {
      display: none;
    }

    nav ul {
      flex-direction: column;
      gap: 0;
      position: absolute;
      width: 100%;
      top: calc(1rem + 40px);
      right: 0;
      padding: 1rem;
      z-index: 1;
      opacity: 0;
      pointer-events: none;
      transition: all .25s ease;
      user-select: none;
      height: calc(100vh - 1rem - 40px);
      align-items: start;
    }

    nav.active {
      background-color: var(--surface-1);
    }

    nav.active ul {
      opacity: 1;
      pointer-events: all;
      background-color: var(--surface-1);
    }

    nav ul li {
      position: relative;
      transition: all .25s ease-out;
      top: -1.5rem;
      border-bottom: 1px solid var(--border);
      width: 100%;
      max-width: none;
      padding: 0;
      font-size: 1.125em;
    }
  
    nav ul li a {
      display: block;
      padding: .75rem 0;
      width: 100%;
      padding-left: 1rem;
    }

    nav ul li:first-child {
      border-top: 1px solid var(--border);
    }

    nav.active ul li {
      top: 0;
    }

    .search-item {
      margin-left: 0;
      width: 100%;
    }

    .search-wrapper {
      width: 100%;
      margin: .5rem 0;
    }

    #search {
      width: 100%;
      padding: .55rem 0;
    }

    .search-kbd {
      display: none;
    }

    #search-results {
      width: 100%;
      top: 100%;
      font-size: 0.875em;
    }
  }
</style>
<style is:global>
  #search-results a {
    display: block;
    text-decoration: none;
    color: var(--text) !important;
    border-radius: var(--radius-sm);
    padding: .5rem;
  }

  #search-results a:hover, #search-results a:focus-visible {
    background-color: var(--primary);
    color: var(--on-primary) !important;
    outline: none;
  }

  #search-results a:hover mark, #search-results a:focus-visible mark {
    background-color: #ffffff;
    color: #000000;
  }

  #search-results a h3 {
    margin-bottom: .5rem;
  }

  #search-results a p {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #search-results mark {
    background-color: var(--primary);
    color: white;
  }

  .separator {
    margin: .5rem .5rem;
    border: none;
    height: 1px;
    background-color: var(--border);
  }
</style>